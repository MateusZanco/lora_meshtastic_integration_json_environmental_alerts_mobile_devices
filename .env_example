# Copie este arquivo para .env para ajustar o ambiente local.
# Não inclua segredos reais no .env_example.
GRADIO_HOST_PORT=7860
MQTT_HOST_PORT=1883

# "mqtt" é o nome do serviço Docker; fora do Compose, use localhost.
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TOPIC=americas-techguard/simulation/rainfall
MQTT_CLIENT_ID=techguard-gradio-simulator
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1

# Parâmetros didáticos da simulação pluviométrica.
RAIN_GAUGE_TIP_MM=0.2
SAMPLE_INTERVAL_MINUTES=5
ACCUMULATION_WINDOW_MINUTES=60
